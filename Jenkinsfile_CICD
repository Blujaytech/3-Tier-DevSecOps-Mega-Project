pipeline {
    agent any
    tools {
        nodejs 'nodejs23'
    }
    environment {
        DOCKERHUB_REPO = 'blujaytech'
        SCANNER_HOME = tool('sonar-scanner')
    }
    stages {
        stage('Git Checkout') {
            steps {
                git branch: 'main',
                    url: 'https://github.com/Blujaytech/3-Tier-DevSecOps-Mega-Project.git'
            }
        }
        stage('Frontend Compilation') {
            steps {
                dir('client') {
                    sh 'find . -name "*.js" -exec node --check {} +'
                }
            }
        }
        stage('Backend Compilation') {
            steps {
                dir('api') {
                    sh 'find . -name "*.js" -exec node --check {} +'
                }
            }
        }
        stage('GitLeaks Scan') {
            steps {
                sh 'gitleaks detect --source ./client --exit-code 1'
                sh 'gitleaks detect --source ./api --exit-code 1'
            }
        }
        stage('SonarQube Analysis') {
            steps {
                withSonarQubeEnv('sonar') {
                    sh """
                        ${SCANNER_HOME}/bin/sonar-scanner \
                        -Dsonar.projectKey=NodeJS-Project \
                        -Dsonar.projectName=NodeJS-Project \
                        -Dsonar.sources=.
                    """
                }
            }
        }
        stage('Quality Gate Check') {
            steps {
                timeout(time: 10, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }
        stage('Trivy Filesystem Scan') {
            steps {
                sh 'trivy fs .'
            }
        }
        stage('Build Backend Docker Image') {
            steps {
                dir('api') {
                    sh "docker build -t ${DOCKERHUB_REPO}/backend:latest ."
                }
            }
        }
        stage('Build Frontend Docker Image') {
            steps {
                dir('client') {
                    sh "docker build -t ${DOCKERHUB_REPO}/frontend:latest ."
                }
            }
        }
        stage('Trivy Backend Image Scan') {
            steps {
                sh "trivy image ${DOCKERHUB_REPO}/backend:latest"
            }
        }
        stage('Trivy Frontend Image Scan') {
            steps {
                sh "trivy image ${DOCKERHUB_REPO}/frontend:latest"
            }
        }
        stage('Push Docker Images') {
            steps {
                script {
                    docker.withRegistry('', 'docker-cred') {
                        sh "docker push ${DOCKERHUB_REPO}/backend:latest"
                        sh "docker push ${DOCKERHUB_REPO}/frontend:latest"
                    }
                }
            }
        }
        stage('Install Cert-Manager') {
            steps {
                script {
                    withKubeConfig(caCertificate: '', clusterName: 'blujay-cluster2', contextName: '', credentialsId: 'k8-token', namespace: 'dev', restrictKubeConfigAccess: false, serverUrl: 'https://D2D17FD56F9CF432FA1CB06A39FDC7FB.gr7.us-east-1.eks.amazonaws.com') {
                        sh '''
                            if ! kubectl get namespace cert-manager > /dev/null 2>&1; then
                                echo "Installing cert-manager..."
                                kubectl apply -f https://github.com/cert-manager/cert-manager/releases/download/v1.14.4/cert-manager.yaml
                                echo "Waiting 90s for cert-manager to be ready..."
                                sleep 90
                            else
                                echo "cert-manager already installed, skipping..."
                                kubectl get pods -n cert-manager
                            fi
                        '''
                    }
                }
            }
        }
        stage('Deployment To Prod') {
            steps {
                script {
                    withKubeConfig(caCertificate: '', clusterName: 'blujay-cluster2', contextName: '', credentialsId: 'k8-token', namespace: 'dev', restrictKubeConfigAccess: false, serverUrl: 'https://D2D17FD56F9CF432FA1CB06A39FDC7FB.gr7.us-east-1.eks.amazonaws.com') {
                        sh 'kubectl apply -f k8s-prod/sc.yaml'
                        sh 'sleep 20'
                        sh 'kubectl apply -f k8s-prod/mysql.yaml -n dev'
                        sh 'kubectl apply -f k8s-prod/backend.yaml -n dev'
                        sh 'kubectl apply -f k8s-prod/frontend.yaml -n dev'
                        sh 'sleep 30'
                        sh 'kubectl apply -f k8s-prod/ci.yaml'
                        sh 'kubectl apply -f k8s-prod/ingress.yaml -n dev'
                        sh 'sleep 30'
                    }
                }
            }
        }
        stage('Verify Deployment To Prod') {
            steps {
                script {
                    withKubeConfig(caCertificate: '', clusterName: 'blujay-cluster2', contextName: '', credentialsId: 'k8-token', namespace: 'dev', restrictKubeConfigAccess: false, serverUrl: 'https://D2D17FD56F9CF432FA1CB06A39FDC7FB.gr7.us-east-1.eks.amazonaws.com') {
                        sh 'kubectl get pods -n dev'
                        sh 'sleep 20'
                        sh 'kubectl get ingress -n dev'
                    }
                }
            }
        }
    }
}
